# Ignore Doxygen generated docs and MkDocs site output.
# NOTE: these used to be blanket `docs/`, `tests/testData`, `src/tools` directory ignores,
# which SHADOWED tracked files under them — any NEW doc page / test fixture / tool was
# silently invisible to `git status`. Replaced with precise patterns for the actually-
# generated / secret artifacts so the source subtrees stay visible.
docs/api/html/
docs/converter/
site/

# tests/testData: keep the committed fixtures (e.g. test_cores.ndjson) visible; ignore only
# the locally-generated / oversized artifacts.
tests/testData/*_result.csv
tests/testData/magnetics.ndjson
tests/testData/*.7z

# src/tools: vendor-scraper outputs, secrets and archives are local-only; the .py tools are not.
src/tools/credentials.json
src/tools/*.ndjson
src/tools/*.html
src/tools/*.7z
src/tools/*.dev

output/
# Claude Code internals (local-only)
.claude/
memory/

# Playwright MCP debug logs (local-only)
.playwright-mcp/

# Test runner artifacts
test-results/

# Stray dev/build outputs that have been mass-cleaned once already
gmon.out
_.svg
bobbin-visible.png
norwe_bobbins.ndjson

# Editor/backup files
*.bak
